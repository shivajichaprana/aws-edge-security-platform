# Sample environment variables for local Terraform execution.
# Copy to .env and fill in real values; .env is gitignored.

# AWS region for the primary stack (S3, Firehose, ALB, Athena, Glue).
AWS_REGION=ap-south-1

# Profile or named SSO/role used by the Terraform provider.
AWS_PROFILE=edge-platform

# us-east-1 is REQUIRED for ACM certs used by CloudFront and for Lambda@Edge.
# Provider alias `aws.us_east_1` is wired to this region.
AWS_REGION_GLOBAL=us-east-1

# Terraform backend (override in -backend-config or backend.tfvars at apply-time).
TF_STATE_BUCKET=shivaji-edge-platform-tfstate
TF_STATE_KEY=aws-edge-security-platform/terraform.tfstate
TF_STATE_LOCK_TABLE=terraform-locks

# Project-level inputs commonly passed via -var.
PROJECT_NAME=edge-security
ENVIRONMENT=dev
ROOT_DOMAIN=example.com
ALB_DNS_NAME=internal-alb-1234567890.ap-south-1.elb.amazonaws.com
